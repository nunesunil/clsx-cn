{
	"name": "clsx-cn",
	"type": "module",
	"version": "1.1.0",
	"description": "clsx, cva, and cn for Tailwind CSS — includes tailwind-merge for conflict-aware cn().",
	"keywords": [
		"tailwind",
		"tailwindcss",
		"clsx",
		"cva",
		"cn",
		"classnames",
		"class-variance-authority",
		"shadcn",
		"shadcn-ui"
	],
	"license": "MIT",
	"author": "nunesunil",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/nunesunil/clsx-cn.git"
	},
	"homepage": "https://github.com/nunesunil/clsx-cn#readme",
	"bugs": {
		"url": "https://github.com/nunesunil/clsx-cn/issues"
	},
	"types": "./dist/index.d.ts",
	"exports": {
		".": "./dist/index.js",
		"./package.json": "./package.json"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"publishConfig": {
		"access": "public"
	},
	"sideEffects": false,
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "pnpm run build",
		"prepack": "pnpm run build"
	},
	"dependencies": {
		"tailwind-merge": "^3"
	},
	"devDependencies": {
		"tsdown": "^0",
		"typescript": "^6"
	}
}
